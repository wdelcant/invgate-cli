{
  "swagger": "2.0",
  "info": {
    "title": "Petstore",
    "version": "1.0.0"
  },
  "host": "petstore.example.com",
  "basePath": "/api",
  "schemes": ["https"],
  "securityDefinitions": {
    "petstore_auth": {
      "type": "oauth2",
      "tokenUrl": "https://petstore.example.com/oauth/token",
      "flow": "application",
      "scopes": {
        "write": "write access",
        "read": "read access"
      }
    }
  },
  "paths": {
    "/pet/": {
      "get": {
        "tags": ["pet"],
        "operationId": "pet_list",
        "summary": "List all pets",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of pets",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "name": {"type": "string"}
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["pet"],
        "operationId": "pet_create",
        "summary": "Create a pet",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "201": {"description": "Pet created"}
        }
      }
    },
    "/pet/{id}/": {
      "get": {
        "tags": ["pet"],
        "operationId": "pet_read",
        "summary": "Get a single pet",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {"description": "A pet"},
          "404": {"description": "Not found"}
        }
      }
    }
  }
}